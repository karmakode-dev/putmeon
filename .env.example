# App
# Local: http://localhost:5173  |  Prod: https://putmeon.karmakode.co
VITE_APP_URL=http://localhost:5173
VITE_USE_MOCK_API=true

# OpenAI Vision (browser dev only — use backend in production)
# When VITE_USE_MOCK_API=false, OpenAI runs server-side via Supabase Edge Function
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_USE_OPENAI_VISION=true

# Backend API (Supabase Edge Function)
# Local: http://127.0.0.1:54321/functions/v1/api
# Prod:  https://YOUR_PROJECT.supabase.co/functions/v1/api
VITE_API_URL=

# Spotify OAuth (client ID only in frontend; secret stays on backend)
VITE_SPOTIFY_CLIENT_ID=

# Contact
VITE_CONTACT_EMAIL=hello@putmeon.app

# Supabase (Google sign-in + profiles)
# Project URL and anon key from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase Dashboard (Authentication → Providers → Google) ---
# Enable Google provider. Add redirect URLs:
#   http://localhost:5173/auth/callback
#   https://putmeon.karmakode.co/auth/callback
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/api/auth/spotify/callback
# APP_URL=https://putmeon.karmakode.co
